@using AssetControl.Entity;
@using AssetControl.Models;

@model ext26_assetcontrol_asset
@{
    ViewBag.Title = "";
    List<ext26_assetcontrol_computer_spec> com_spec = ViewBag.com_spec as List<ext26_assetcontrol_computer_spec>;
    List<DEPT_CUSTOM> depts = ViewBag.depts as List<DEPT_CUSTOM>;
    List<USER_CUSTOM> users = ViewBag.users as List<USER_CUSTOM>;
}

<div class="dashboard-main-body">

    <div class="card">
        <div class="card-header d-flex flex-row justify-content-between align-items-center ">
            <div class="d-flex flex-column">
                <h1 class="h3 mb-0">Create Asset</h1>
                <small class="text-muted">Add a new Asset to the system</small>
            </div>
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-outline-secondary" })
        </div>

        <form action="@Url.Action("Create","Asset")" method="post" enctype="multipart/form-data" id="createForm" novalidate>

            @Html.AntiForgeryToken()

            <div class="card-body">
                <div class="alert alert-warning d-none" id="formWarning">
                    <iconify-icon icon="mdi:alert-circle-outline" width="18" height="18"></iconify-icon>
                    กรุณากรอกข้อมูลให้ครบทุกช่อง
                </div>
                <div class="col-12 col-lg-8">
                    <div class="row">

                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">Asset <span class="text-danger">*</span></label>
                            <input required type="text" id="assetNumberInput" name="asset_number" value="@Model.asset_number" class="form-control" />
                            <div class="invalid-feedback" id="assetNumberError">กรุณากรอก Asset Number</div>
                            <div class="text-danger small d-none" id="assetDuplicateMsg">
                                <iconify-icon icon="mdi:alert-circle" width="14"></iconify-icon>
                                Asset Number นี้มีอยู่ในระบบแล้ว
                            </div>
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label">Computer Spec <span class="text-danger">*</span></label>
                            <select class="form-select my-select" name="id_com_spec" required>
                                <option value="" disabled selected>-- Computer Spec --</option>
                                @if (com_spec != null && com_spec.Count() > 0)
                                {
                                    foreach (var item in com_spec)
                                    {
                                        <option value="@item.id_com_spec" data-brand="@item.brand" data-model="@item.model" data-cpu="@item.cpu" data-gpu="@item.gpu" data-memory="@item.memory" data-disk="@item.disk_size" data-os="@item.os">@item.brand - @item.model - @item.cpu - @item.gpu - @item.memory - @item.disk_size - @item.os</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">กรุณาเลือก Computer Spec</div>
                        </div>



                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">Serial Number <span class="text-danger">*</span></label>
                            <input required type="text" id="serialNumberInput" name="serial_number" value="@Model.serial_number" class="form-control" />
                            <div class="invalid-feedback">กรุณากรอก Serial Number</div>
                            <div class="text-danger small d-none" id="serialDuplicateMsg">
                                <iconify-icon icon="mdi:alert-circle" width="14"></iconify-icon>
                                Serial Number นี้มีอยู่ในระบบแล้ว
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">Status <span class="text-danger">*</span></label>
                            @Html.DropDownList("id_status", (SelectList)ViewBag.statuses, "-- Select status --", new { @class = "form-select", required = "required" })
                            <div class="invalid-feedback">กรุณาเลือก Status</div>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">Create by <span class="text-danger">*</span></label>
                            <select class="form-select my-select" name="emp" required>
                                <option value="" disabled selected>-- เลือกชื่อ --</option>
                                @if (users != null && users.Count() > 0)
                                {
                                    foreach (var item in users)
                                    {
                                        <option value="@item.UID">@item.EmpID - @item.FName @item.LName</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">กรุณาเลือกชื่อ</div>
                        </div>


                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">แผนก <span class="text-danger">*</span></label>
                            <select class="form-select my-select" name="dept" required>
                                <option value="" disabled selected>-- เลือกแผนก --</option>
                                @if (depts != null && depts.Count > 0)
                                {
                                    foreach (var item in depts)
                                    {
                                        <option value="@item.DeptId">@item.DepName @item.FactoryId</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">กรุณาเลือกแผนก</div>
                        </div>


                        <div class="row">
                            <!-- Left: Preview -->
                            <div class="col-12 col-lg-4 mb-3">

                            <div class="card p-3">

                             <div class="text-center mb-3" id="previewimage" >
                                   
                            </div>

                        <div class="col-12 mb-3">
                                <label class="form-label">Upload Photo</label>
                                @* input type="file" ส่งไฟล์รูปไปกับ form
                                   - name="photo"     → ต้องตรงกับ parameter HttpPostedFileBase photo ใน Controller
                                   - accept="image/*" → จำกัดให้เลือกได้เฉพาะไฟล์รูปภาพ
                                   - form ต้องมี enctype="multipart/form-data" ถึงจะส่งไฟล์ได้ *@
                                <input id="photoInput" type="file" name="photo" accept="image/*" class="form-control" />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Remark</label>
                                <textarea name="remark" class="form-control" rows="3" placeholder="Enter a description...">@Model.remark</textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <div class="card-footer d-flex flex-row gap-3">

                <button type="submit" class="btn btn-primary-600 radius-8 px-20 py-11 d-flex align-items-center gap-2">
                    <iconify-icon icon="iconamoon:arrow-down-5-circle-light" width="24" height="24"></iconify-icon>
                    Save
                </button>

                <a href="@Url.Action("Index")"
                   class="btn btn-outline-secondary radius-8 px-20 py-11 d-flex align-items-center gap-2">
                    <iconify-icon icon="mdi:close-circle-outline" width="24" height="24"></iconify-icon>
                    Cancel
                </a>
            </div>

        </form>
    </div>

</div>

<script>
    document.getElementById("photoInput").addEventListener("change", e => {
        const image = e.target.files[0];
        const previewimage = document.getElementById("previewimage")
        if (image) {
            previewimage.innerHTML = "";
            const img = document.createElement("img");
            img.src.width = 100;
            img.src.height = 100;
            img.src = URL.createObjectURL(image);
            previewimage.appendChild(img)
        }
    })
</script>
