@using AssetControl.Models;
@model List<ext26_assetcontrol_user_role>
@{
    ViewBag.Title = "User Roles";
}

<h2>กำหนดสิทธิ์ผู้ใช้</h2>

<p>
    @Html.ActionLink("Create New", "Create", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-bordered">
    <tr>
        <th>Username</th>
        <th>Role</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ext26_assetcontrol_user?.username</td>
            <td>@item.ext26_assetcontrol_role?.role_name</td>
            <td>
                @Html.ActionLink("Delete", "Delete", new { id = item.id_user_role }, new { @class = "btn btn-danger btn-sm" })
            </td>
        </tr>
    }
</table>