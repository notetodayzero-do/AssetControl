using AssetControl.Entity;
using AssetControl.Models;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Web;
using System.Web.Mvc;

namespace AssetControl.Controllers
{
    
    public class AssetController : BaseController
    {
        Entity.EXT26_ASSETCONTROLEntities db = new Entity.EXT26_ASSETCONTROLEntities();
       
        // หน้าแสดงรายการ Asset (GET)
        public ActionResult Index()
        {
            // ดึงข้อมูล Asset ทั้งหมด
            List<ext26_assetcontrol_asset> asset = db.ext26_assetcontrol_asset.ToList();

            // ดึงข้อมูลแผนกจาก Entity และแมปเป็น DepartmentsCustom เพื่อใช้สร้าง dropdown
            var depts = db.ext26_assetcontrol_department
                .Select(d => new AssetControl.Models.DepartmentsCustom { id = d.id_dpm, department = d.name_dpm })
                .ToList();
            ViewBag.Departments = new SelectList(depts, "id", "department");

            // ดึงข้อมูลผู้ใช้จากฐานข้อมูล API (db_api อยู่ใน BaseController) และแมปเป็น UsersCustom
            var users = db_api.Users
                .Select(u => new AssetControl.Models.UsersCustom
                {
                    UID = u.UID,
                    UserName = u.UserName,
                    Password = u.Password,
                    FName = u.FName,
                    LName = u.LName,
                    Email = u.Email,
                    EmpID = u.EmpID,
                    Factory = u.Factory
                })
                .ToList();
            ViewBag.Users = new SelectList(users, "UID", "UserName");

            // ส่ง model ไปยัง view
            return View(asset);
        }

        public ActionResult Create()
        {
            ext26_assetcontrol_asset model = new ext26_assetcontrol_asset();
            model.create_date = DateTime.Now;

            // โหลดรายการสเปค และ สถานะ สำหรับแสดงเป็น dropdown ในฟอร์ม
            ViewBag.Specs = new SelectList(db.ext26_assetcontrol_computer_spec.ToList(), "id_com_spec", "brand");
            ViewBag.Statuses = new SelectList(db.ext26_assetcontrol_status.ToList(), "id_status", "status_name");
            return View(model);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public ActionResult Create(ext26_assetcontrol_asset asset)
        {
            try
            {
                if (ModelState.IsValid)
                {
                    asset.create_date = DateTime.Now;
                    var current = GetUser();
                    if (current != null)
                    {
                        asset.create_by = current.UserName ?? current.EmpID;
                    }
                    // default status if not provided
                    if (asset.id_status == 0)
                    {
                        asset.id_status = db.ext26_assetcontrol_status.OrderBy(s => s.id_status).FirstOrDefault()?.id_status ?? 1;
                    }

                    db.ext26_assetcontrol_asset.Add(asset);
                    db.SaveChanges();
                    // แจ้งผลสำเร็จเป็นภาษาไทย
                    TempData["Success"] = "สร้าง Asset เรียบร้อยแล้ว";
                    return RedirectToAction("Index");
                }
            }
            catch (Exception ex)
            {
                // เก็บข้อความข้อผิดพลาด
                TempData["Error"] = ex.Message;
            }

            // reload dropdowns on error
            ViewBag.Specs = new SelectList(db.ext26_assetcontrol_computer_spec.ToList(), "id_com_spec", "brand", asset.id_com_spec);
            ViewBag.Statuses = new SelectList(db.ext26_assetcontrol_status.ToList(), "id_status", "status_name", asset.id_status);
            // คืนค่า view พร้อมข้อมูลเดิมเมื่อเกิด error
            return View(asset);
        }

        public ActionResult Update()
        {
            return View();
        }
    }
}

