@using AssetControl.Entity;
@model ext26_assetcontrol_asset
@{
    ViewBag.Title = "";
}



<div class="dashboard-main-body">

    <div class="card">
        <div class="card-header d-flex flex-row justify-content-between align-items-center ">
            <div class="d-flex flex-column">
                <h1 class="h3 mb-0">Create Asset</h1>
                <small class="text-muted">Add a new Asset to the system</small>
            </div>
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-outline-secondary" })
        </div>

        <form action="@Url.Action("PostData","Asset")" method="post">

            @Html.AntiForgeryToken()



            <div class="card-body row">
                <div class="col-12 col-lg-4">
                    <label class="form-label">Asset</label>
                    <input required type="text" name="Asset" value="@Model.asset_number" class="form-control" />
                </div>
            </div>

            <div class="card-body row">
                <div class="col-12 col-lg-4">
                    <label class="form-label">Serial_Number</label>
                    <input required type="text" name="serial_number" value="@Model.serial_number" class="form-control" />
                </div>
            </div>

            <div class="card-body row">
                <div class="col-12 col-lg-4">
                    <label class="form-label">Id_Com_Spec</label>
                    <input required type="text" name="Id_com_spec" value="@Model.id_com_spec" class="form-control" />
                </div>
            </div>

            <div class="card-body row">
                <div class="col-12 col-lg-4">
                    <label class="form-label">Id_Status</label>
                    <input required type="text" name="Id_Status" value="@Model.id_status" class="form-control" />
                </div>
            </div>

            <div class="card-body row">
                <div class="col-12 col-lg-4">
                    <label class="form-label">Dept</label>
                    <input required type="text" name="dept" value="@Model.dept" class="form-control" />
                </div>
            </div>

            <div class="card-body row">
                <div class="col-12 col-lg-4">
                    <label class="form-label">Emp</label>
                    <input required type="text" name="emp" value="@Model.emp" class="form-control" />
                </div>
            </div>

            <div class="card-body row">
                <div class="col-12 col-lg-4">
                    <label class="form-label">Create_by</label>
                    <input required type="text" name="create_by" value="@Model.create_by" class="form-control" />
                </div>
            </div>



            <div class="card-footer d-flex flex-row gap-3">

                <button type="submit" class="btn btn-primary-600 radius-8 px-20 py-11 d-flex align-items-center gap-2">
                    <iconify-icon icon="iconamoon:arrow-down-5-circle-light" width="24" height="24"></iconify-icon>
                    Save
                </button>

                <a href="@Url.Action("Index")"
                   class="btn btn-outline-secondary radius-8 px-20 py-11 d-flex align-items-center gap-2">
                    <iconify-icon icon="mdi:close-circle-outline" width="24" height="24"></iconify-icon>
                    Cancel
                </a>
            </div>

        </form>
    </div>

</div>