@using AssetControl.Entity;
@using AssetControl.Models;

@model ext26_assetcontrol_asset
@{
    ViewBag.Title = "";
    List<ext26_assetcontrol_computer_spec> com_spec = ViewBag.com_spec as List<ext26_assetcontrol_computer_spec>;
    List<DEPT_CUSTOM> depts = ViewBag.depts as List<DEPT_CUSTOM>;
    List<USER_CUSTOM> users = ViewBag.users as List<USER_CUSTOM>;
}

<div class="dashboard-main-body">

    <div class="card">
        <div class="card-header d-flex flex-row justify-content-between align-items-center ">
            <div class="d-flex flex-column">
                <h1 class="h3 mb-0">Create Asset</h1>
                <small class="text-muted">Add a new Asset to the system</small>
            </div>
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-outline-secondary" })
        </div>

        <form action="@Url.Action("Create","Asset")" method="post" enctype="multipart/form-data" id="createForm" novalidate>

            @Html.AntiForgeryToken()

            <div class="card-body">
                <div class="alert alert-warning d-none" id="formWarning">
                    <iconify-icon icon="mdi:alert-circle-outline" width="18" height="18"></iconify-icon>
                    กรุณากรอกข้อมูลให้ครบทุกช่อง
                </div>
                <div class="col-12 col-lg-8">
                    <div class="row">

                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">Asset <span class="text-danger">*</span></label>
                            <input required type="text" id="assetNumberInput" name="asset_number" value="@Model.asset_number" class="form-control" />
                            <div class="invalid-feedback" id="assetNumberError">กรุณากรอก Asset Number</div>
                            <div class="text-danger small d-none" id="assetDuplicateMsg">
                                <iconify-icon icon="mdi:alert-circle" width="14"></iconify-icon>
                                Asset Number นี้มีอยู่ในระบบแล้ว
                            </div>
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label">Computer Spec <span class="text-danger">*</span></label>
                            <select class="form-select my-select" name="id_com_spec" required>
                                <option value="" disabled selected>-- Computer Spec --</option>
                                @if (com_spec != null && com_spec.Count() > 0)
                                {
                                    foreach (var item in com_spec)
                                    {
                                        <option value="@item.id_com_spec" data-brand="@item.brand" data-model="@item.model" data-cpu="@item.cpu" data-gpu="@item.gpu" data-memory="@item.memory" data-disk="@item.disk_size" data-os="@item.os">@item.brand - @item.model - @item.cpu - @item.gpu - @item.memory - @item.disk_size - @item.os</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">กรุณาเลือก Computer Spec</div>
                        </div>



                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">Serial Number <span class="text-danger">*</span></label>
                            <input required type="text" id="serialNumberInput" name="serial_number" value="@Model.serial_number" class="form-control" />
                            <div class="invalid-feedback">กรุณากรอก Serial Number</div>
                            <div class="text-danger small d-none" id="serialDuplicateMsg">
                                <iconify-icon icon="mdi:alert-circle" width="14"></iconify-icon>
                                Serial Number นี้มีอยู่ในระบบแล้ว
                            </div>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">Status <span class="text-danger">*</span></label>
                            @Html.DropDownList("id_status", (SelectList)ViewBag.statuses, "-- Select status --", new { @class = "form-select", required = "required" })
                            <div class="invalid-feedback">กรุณาเลือก Status</div>
                        </div>

                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">Create by <span class="text-danger">*</span></label>
                            <select class="form-select my-select" name="emp" required>
                                <option value="" disabled selected>-- เลือกชื่อ --</option>
                                @if (users != null && users.Count() > 0)
                                {
                                    foreach (var item in users)
                                    {
                                        <option value="@item.UID">@item.EmpID - @item.FName @item.LName</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">กรุณาเลือกชื่อ</div>
                        </div>


                        <div class="col-12 col-lg-6 mb-3">
                            <label class="form-label">แผนก <span class="text-danger">*</span></label>
                            <select class="form-select my-select" name="dept" required>
                                <option value="" disabled selected>-- เลือกแผนก --</option>
                                @if (depts != null && depts.Count > 0)
                                {
                                    foreach (var item in depts)
                                    {
                                        <option value="@item.DeptId">@item.DepName @item.FactoryId</option>
                                    }
                                }
                            </select>
                            <div class="invalid-feedback">กรุณาเลือกแผนก</div>
                        </div>


                        <div class="row">
                            <!-- Left: Preview -->
                            <div class="col-12 col-lg-4 mb-3">
                                <div class="card p-3">
                                    <div class="text-center mb-3">
                                        <img id="assetPreviewImg" src="/Content/images/placeholder.png" alt="Asset" class="img-fluid" style="max-height:180px; object-fit:contain;" />
                                    </div>
                                    <h5 id="previewBrand">Brand - Model</h5>
                                    <p id="previewSpecs" class="text-muted small">CPU / GPU / Memory / Disk / OS</p>
                                    <p class="mb-1"><strong>Serial:</strong> <span id="previewSerial">-</span></p>
                                    <p class="mb-0"><strong>Status:</strong> <span id="previewStatus">-</span></p>
                                </div>
                            </div>

                            <div class="col-12 mb-3">
                                <label class="form-label">Upload Photo</label>
                                <input id="photoInput" type="file" name="photo" accept="image/*" class="form-control" />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Remark</label>
                                <textarea name="remark" class="form-control" rows="3" placeholder="Enter a description...">@Model.remark</textarea>
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <div class="card-footer d-flex flex-row gap-3">

                <button type="submit" class="btn btn-primary-600 radius-8 px-20 py-11 d-flex align-items-center gap-2">
                    <iconify-icon icon="iconamoon:arrow-down-5-circle-light" width="24" height="24"></iconify-icon>
                    Save
                </button>

                <a href="@Url.Action("Index")"
                   class="btn btn-outline-secondary radius-8 px-20 py-11 d-flex align-items-center gap-2">
                    <iconify-icon icon="mdi:close-circle-outline" width="24" height="24"></iconify-icon>
                    Cancel
                </a>
            </div>

        </form>
    </div>

</div>

<script>
    (function () {
        var specSelect = document.querySelector('select[name="id_com_spec"]');
        var previewBrand = document.getElementById('previewBrand');
        var previewSpecs = document.getElementById('previewSpecs');
        var previewSerial = document.getElementById('previewSerial');
        var previewStatus = document.getElementById('previewStatus');
        var previewImg = document.getElementById('assetPreviewImg');
        var fileInput = document.getElementById('photoInput');

        function updateFromSelect() {
            if (!specSelect) return;
            var opt = specSelect.options[specSelect.selectedIndex];
            if (!opt) return;
            var brand = opt.dataset.brand || '';
            var model = opt.dataset.model || '';
            var cpu = opt.dataset.cpu || '';
            var gpu = opt.dataset.gpu || '';
            var memory = opt.dataset.memory || '';
            var disk = opt.dataset.disk || '';
            var os = opt.dataset.os || '';
            if (previewBrand) previewBrand.textContent = brand + (model ? ' - ' + model : '');
            if (previewSpecs) previewSpecs.textContent = [cpu, gpu, memory, disk, os].filter(Boolean).join(' / ');
        }

        if (specSelect) specSelect.addEventListener('change', updateFromSelect);

        if (fileInput) {
            fileInput.addEventListener('change', function () {
                var f = this.files && this.files[0];
                if (!f) {
                    previewImg.src = '/Content/images/placeholder.png';
                    return;
                }
                // rename preview label to match asset_number
                var assetInput = document.querySelector('input[name="asset_number"]');
                var assetNo = assetInput && assetInput.value.trim() ? assetInput.value.trim() : '';
                if (assetNo) {
                    var ext = f.name.substring(f.name.lastIndexOf('.'));
                    var dt = new DataTransfer();
                    dt.items.add(new File([f], assetNo.replace(/ /g, '_') + ext, { type: f.type }));
                    fileInput.files = dt.files;
                    f = fileInput.files[0];
                }
                var reader = new FileReader();
                reader.onload = function (e) { if (previewImg) previewImg.src = e.target.result; };
                reader.readAsDataURL(f);
            });
        }

        var serialInput = document.querySelector('input[name="serial_number"]');
        if (serialInput) serialInput.addEventListener('input', function () { if (previewSerial) previewSerial.textContent = this.value || '-'; });

        var statusSelect = document.querySelector('select[name="id_status"]');
        if (statusSelect) statusSelect.addEventListener('change', function () {
            var opt = statusSelect.options[statusSelect.selectedIndex];
            if (previewStatus) previewStatus.textContent = opt ? opt.text : '-';
        });

        // init preview values
        updateFromSelect();
        if (previewSerial) previewSerial.textContent = serialInput ? serialInput.value || '-' : '-';
        if (previewStatus) {
            var sel = document.querySelector('select[name="id_status"]');
            if (sel) { var o = sel.options[sel.selectedIndex]; previewStatus.textContent = o ? o.text : '-'; }
        }
        // duplicate asset_number check
        var assetInput = document.getElementById('assetNumberInput');
        var dupMsg = document.getElementById('assetDuplicateMsg');
        var isDup = false;
        if (assetInput) {
            assetInput.addEventListener('blur', function () {
                var val = this.value.trim();
                if (!val) return;
                fetch('@Url.Action("CheckAssetNumber","Asset")?assetNumber=' + encodeURIComponent(val))
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        isDup = data.exists;
                        if (isDup) {
                            assetInput.classList.add('is-invalid');
                            if (dupMsg) dupMsg.classList.remove('d-none');
                        } else {
                            assetInput.classList.remove('is-invalid');
                            if (dupMsg) dupMsg.classList.add('d-none');
                        }
                    });
            });
        }

        // duplicate serial_number check
        var serialInput2 = document.getElementById('serialNumberInput');
        var serialDupMsg = document.getElementById('serialDuplicateMsg');
        var isSerialDup = false;
        if (serialInput2) {
            serialInput2.addEventListener('blur', function () {
                var val = this.value.trim();
                if (!val) return;
                fetch('@Url.Action("CheckSerialNumber","Asset")?serialNumber=' + encodeURIComponent(val))
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        isSerialDup = data.exists;
                        if (isSerialDup) {
                            serialInput2.classList.add('is-invalid');
                            if (serialDupMsg) serialDupMsg.classList.remove('d-none');
                        } else {
                            serialInput2.classList.remove('is-invalid');
                            if (serialDupMsg) serialDupMsg.classList.add('d-none');
                        }
                    });
            });
        }

        // validate on submit
        var form = document.getElementById('createForm');
        var warning = document.getElementById('formWarning');
        if (form) {
            form.addEventListener('submit', function (e) {
                if (isDup || isSerialDup || !form.checkValidity()) {
                    e.preventDefault();
                    form.classList.add('was-validated');
                    if (warning) warning.classList.remove('d-none');
                    warning.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } else {
                    if (warning) warning.classList.add('d-none');
                }
            });
        }
    })();
</script>
