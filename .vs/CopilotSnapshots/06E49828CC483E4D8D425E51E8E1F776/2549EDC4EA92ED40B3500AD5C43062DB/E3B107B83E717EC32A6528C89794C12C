@using AssetControl.Models
@using ExtsmartAuthentication.Helpers;

@model User

@{
    Layout = null;
}

@Html.ExtsmartStyles()
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    @Styles.Render("~/Content/css")
</head>
<body>


        <section class="auth bg-base d-flex flex-wrap">
            <div class="auth-left d-lg-block d-none">
                <div class="d-flex align-items-center flex-column h-100 justify-content-center">
                    <img src="assets/images/auth/auth-img.png" alt="">
                </div>


            </div>
            <div class="auth-right py-32 px-24 d-flex flex-column justify-content-center">

                <div class="max-w-464-px mx-auto w-100">
                    <div>
                        <a href="index.php" class="mb-40 max-w-290-px">
                            <img src="assets/images/logo.png" alt="">
                        </a>
                        <h4 class="mb-12">Sign In to your Account</h4>
                        <p class="mb-32 text-secondary-light text-lg">Welcome back! please enter your detail</p>
                        @Html.ExtsmartRender()
                    </div>
                    <form action="@Url.Action("login","login")" method="post">
                        <div class="icon-field mb-16">
                            <span class="icon top-50 translate-middle-y">
                                <iconify-icon icon="mdi:user" width="24" height="24"></iconify-icon>
                            </span>
                            <input type="text" name="UserName" class="form-control h-56-px bg-neutral-50 radius-12" placeholder="Username">
                        </div>
                        <div class="position-relative mb-20">
                            <div class="icon-field">
                                <span class="icon top-50 translate-middle-y">
                                    <iconify-icon icon="solar:lock-password-outline"></iconify-icon>
                                </span>
                                <input type="password" value="" name="password" class="form-control h-56-px bg-neutral-50 radius-12" id="your-password" placeholder="Password">
                            </div>
                            <span class="toggle-password ri-eye-line cursor-pointer position-absolute end-0 top-50 translate-middle-y me-16 text-secondary-light" data-toggle="#your-password"></span>
                        </div>


                        <button type="submit" class="btn btn-primary text-sm btn-sm px-12 py-16 w-100 radius-12 mt-32"> Sign In</button>

                        <div class="mt-32 center-border-horizontal text-center">
                            <span class="bg-base z-1 px-4">Or sign in with</span>
                        </div>

                        <div class="mt-32 text-center text-sm">
                            <p class="mb-0">Don’t have an account? <a href="@Url.Action("create","employee")" class="text-primary-600 fw-semibold">Sign Up</a></p>
                        </div>

                        @if (TempData["Fail"] != null)
                        {
                            <div class="mt-3 alert alert-danger">
                                @TempData["Fail"].ToString()
                            </div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="mt-3 alert alert-danger">@TempData["Error"].ToString()</div>
                        }

                    </form>
                </div>
            </div>
        </section>


        @Html.ExtsmartScripts("qrcode", "login")
        @Scripts.Render("~/bundles/jquery")
        @Scripts.Render("~/bundles/bootstrap")
    </body>
</html>










