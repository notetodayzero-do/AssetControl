@using AssetControl.Entity;
@model ext26_assetcontrol_computer_spec

@{
    ViewBag.Title = "Cancel Spec";
}

<h2>Cancel Spec</h2>

<dl class="dl-horizontal">
    <dt>Brand</dt>
    <dd>@Model.brand</dd>
    <dt>Model</dt>
    <dd>@Model.model</dd>
    <dt>CPU</dt>
    <dd>@Model.cpu</dd>
    <dt>Remark</dt>
    <dd>@Model.remark</dd>
</dl>

@using (Html.BeginForm("Cancel", "ComputerSpec", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.id_com_spec)
    <button type="submit" class="btn btn-danger">Confirm Cancel</button>
    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-default" })
}
