@using AssetControl.Entity;
@model List<ext26_assetcontrol_computer_spec>
@{
    ViewBag.Title = "";
    List<ext26_assetcontrol_computer_spec> typecoms = ViewBag.typecoms;
    var user = Session["USER"] as User;
}

<h2>Index</h2>

<div class="card basic-data-table">
    <div class="card-header d-flex align-items-baseline justify-content-between">
        <h5 class="card-title mb-0">Computer Spec</h5>
        <a class="btn btn-primary" href="@Url.Action("Create", "ComputerSpec")">
            Create
        </a>
    </div>
    <div class="card-body">
        <table class="table bordered-table mb-0" id="dataTable" data-page-length='10'>
            <thead>
                <tr>
                    <th scope="col">ID</th>
                    <th scope="col">Brand</th>
                    <th scope="col">Model</th>
                    <th scope="col">CPU</th>
                    <th scope="col">GPU</th>
                    <th scope="col">Memory</th>
                    <th scope="col">Disk Size</th>
                    <th scope="col">OS</th>
                    <th scope="col">Device Type</th>
                    <th scope="col">Remark</th>
                    <th scope="col">Create_by</th>
                    <th scope="col">Create_Date</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.id_com_spec</td>
                            <td>@item.brand</td>
                            <td>@item.model</td>
                            <td>@item.cpu</td>
                            <td>@item.gpu</td>
                            <td>@item.memory</td>
                            <td>@item.disk_size</td>
                            <td>@item.os</td>
                            <td>@item.ext26_assetcontrol_type_computer.type_computer</td>
                            <td>@item.remark</td>
                            <td>@user.EmpID</td>
                            <td>@(item.create_date.ToString("yyyy-MM-dd HH:mm"))</td>
                        </tr>
                    }
                }
           
                
            </tbody>
        </table>
    </div>
</div>
@section scripts{
    <script>
        $(document).ready(function () {
            $("#dataTable").DataTable();
        });
    </script>

}