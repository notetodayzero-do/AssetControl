@{
    ViewBag.Title = "Delete UserRole";
}

<h2>ยืนยันการลบสิทธิ์</h2>

<div>
    <h4>Are you sure to delete this user role?</h4>
    <dl class="dl-horizontal">
        <dt>User</dt>
        <dd>@(ViewBag.UserName ?? "-")</dd>
        <dt>Role</dt>
        <dd>@(ViewBag.RoleName ?? "-")</dd>
    </dl>

    @using (Html.BeginForm("DeleteConfirmed", "UserRole", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        
        <button type="submit" class="btn btn-danger">Delete</button>
        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-default" })
    }
</div>
